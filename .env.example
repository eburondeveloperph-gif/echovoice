# EchoLabs server-side settings
ECHOLABS_SUGAR=
ECHOLABS_SALT=https://api.elevenlabs.io
ECHOLABS_LIME=echo-tts@v2.5
ECHOLABS_PEPPER=true
ECHOLABS_MINT=echo-stt@v2
ECHOLABS_COCOA=clone_mode_default
ECHOLABS_VANILLA=realtime_mode_default
ECHOLABS_ICE=120rpm

# Optional runtime controls
ECHOLABS_DEMO_MODE=true
ADMIN_TOKEN=change-me-admin-token
UI_ORIGIN=http://localhost:4173
RATE_LIMIT_PER_MINUTE=120
DATA_ROOT=/data
API_PORT=8010
UI_PORT=4173

# Invisible TTS text editor (remote Ollama)
TTS_EDITOR_ENABLED=true
OLLAMA_BASE_URL=http://168.231.78.113:11434
OLLAMA_MODEL=gpt-oss-20b
OLLAMA_TIMEOUT_SECONDS=6
OLLAMA_EDITOR_SSML=true
OLLAMA_SHORT_TEXT_WORDS=8
